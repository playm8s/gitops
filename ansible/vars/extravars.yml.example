---

rke2_cluster_cidr: "172.16.0.0/16,fda8:af7c:f3da::/64"
rke2_service_cidr: "172.18.0.0/16,fd4e:73c9:dc74::/112"
rke2_cluster_dns: "172.18.0.10,fd4e:73c9:dc74::10"

flux_github_url: ssh://git@github.com/playm8s/gitops.git
flux_github_branch: main
flux_github_repo_path: /flux
flux_github_ssh_private_key_file: "{{ playbook_dir }}/../../sshkey/id_ed25519.pm8s"

cilium_version: 1.19.1

cilium_helm_values:
  operator:
    replicas: 1
  cni:
    exclusive: false
  kubeProxyReplacement: true
  k8sServiceHost: "rke2-server"
  k8sServicePort: 6443
  routingMode: tunnel
  tunnelProtocol: geneve
  bpfClockProbe: true
  loadBalancer:
    mode: dsr
    dsrDispatch: geneve
  bpf:
    datapathMode: netkit
    masquerade: true
    preallocateMaps: true
    distributedLRU:
      enabled: true
    mapDynamicSizeRatio: 0.08
  pmtuDiscovery:
    enabled: true
  rollOutCiliumPods: true
  sctp:
    enabled: true
  hubble:
    enabled: false
    relay:
      enabled: false
  encryption:
    enabled: true
    type: wireguard
  socketLB:
    enabled: true
  externalIPs:
    enabled: true
  hostPort:
    enabled: true
  nodePort:
    enabled: true
  bgpControlPlane:
    enabled: true
  ipv4NativeRoutingCIDR: ""
  ipv6NativeRoutingCIDR: ""
  enableIPv4Masquerade: true
  enableIPv6Masquerade: true
  ipv4:
    enabled: true
  ipv6:
    enabled: true
  endpointRoutes:
    enabled: true
  envoy:
    enabled: false
  ipam:
    mode: multi-pool
    operator:
      autoCreateCiliumPodIPPools:
        default:
          ipv4:
            cidrs:
              - "172.16.0.0/16"
            maskSize: 24
          ipv6:
            cidrs:
              - "fda8:af7c:f3da::/64"
            maskSize: 80
